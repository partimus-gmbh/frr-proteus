{# Shared 'neighbor X ...' line macros, used for real neighbors and
peer-groups alike: in FRR a peer-group is configured with exactly the
same commands, so both call sites pass the peer-group name or the
neighbor address as `addr` and the entity itself as `n`.

session_lines: session-level lines at 'router bgp' level, in
bgp_config_write_peer_global()'s emission order (bgpd/bgp_vty.c). The
remote-as / peer-group / interface header lines are NOT here -- their
shape differs between neighbors and peer-groups, so bgp.conf.j2 renders
them at the call site.

af_lines: per-address-family lines inside an 'address-family' block, in
bgp_config_write_peer_af()'s + bgp_config_write_filter()'s order, plus
per-neighbor dampening (bgp_config_write_peer_damp in bgp_damp.c --
FRR emits it before the peer's other AF lines, we append it after;
placement inside the AF block is free). FRR installs these commands
with identical text in every family, so one macro serves all address
families. #}
{% macro session_lines(addr, n) %}
{% set la_asn = asn_text(n.local_as) %}
{% if la_asn %}
{% set la_np = " no-prepend" if n.local_as.no_prepend else "" %}
{% set la_ra = " replace-as" if n.local_as.replace_as else "" %}
{% set la_da = " dual-as" if n.local_as.dual_as else "" %}
 neighbor {{ addr }} local-as {{ la_asn }}{{ la_np }}{{ la_ra }}{{ la_da }}
{% endif %}
{% if n.description %}
 neighbor {{ addr }} description {{ n.description }}
{% endif %}
{# shutdown: the message rides on the same line when present
   (bgp_config_write_peer_global writes either form, never both). #}
{% if n.shutdown.enabled %}
{% set sd_msg = " message " ~ n.shutdown.message if n.shutdown.message else "" %}
 neighbor {{ addr }} shutdown{{ sd_msg }}
{% endif %}
{% if n.shutdown.rtt.threshold is not none %}
{% set sd_count = " count " ~ n.shutdown.rtt.count if n.shutdown.rtt.count is not none else "" %}
 neighbor {{ addr }} shutdown rtt {{ n.shutdown.rtt.threshold }}{{ sd_count }}
{% endif %}
{% if n.bfd.enabled %}
 neighbor {{ addr }} bfd
{% endif %}
{% if n.bfd.check_control_plane_failure %}
 neighbor {{ addr }} bfd check-control-plane-failure
{% endif %}
{% if n.bfd.profile %}
 neighbor {{ addr }} bfd profile {{ n.bfd.profile }}
{% endif %}
{% if n.password %}
 neighbor {{ addr }} password {{ n.password }}
{% endif %}
{% if n.solo %}
 neighbor {{ addr }} solo
{% endif %}
{% if n.port is not none %}
 neighbor {{ addr }} port {{ n.port }}
{% endif %}
{% if n.source_interface %}
 neighbor {{ addr }} interface {{ n.source_interface }}
{% endif %}
{% if n.tcp_mss is not none %}
 neighbor {{ addr }} tcp-mss {{ n.tcp_mss }}
{% endif %}
{% if n.passive %}
 neighbor {{ addr }} passive
{% endif %}
{# 255 is MAXTTL; FRR writes it back as the bare 'ebgp-multihop'. #}
{% if n.ebgp_multihop == 255 %}
 neighbor {{ addr }} ebgp-multihop
{% elif n.ebgp_multihop %}
 neighbor {{ addr }} ebgp-multihop {{ n.ebgp_multihop }}
{% endif %}
{% if n.aigp %}
 neighbor {{ addr }} aigp
{% endif %}
{% if n.graceful_shutdown %}
 neighbor {{ addr }} graceful-shutdown
{% endif %}
{% if n.local_role.role %}
{% set lr_strict = " strict-mode" if n.local_role.strict_mode else "" %}
 neighbor {{ addr }} local-role {{ n.local_role.role }}{{ lr_strict }}
{% endif %}
{% if n.oad %}
 neighbor {{ addr }} oad
{% endif %}
{% if n.ttl_security_hops %}
 neighbor {{ addr }} ttl-security hops {{ n.ttl_security_hops }}
{% endif %}
{% if n.disable_connected_check %}
 neighbor {{ addr }} disable-connected-check
{% endif %}
{% if n.disable_link_bw_encoding_ieee %}
 neighbor {{ addr }} disable-link-bw-encoding-ieee
{% endif %}
{% if n.extended_link_bandwidth %}
 neighbor {{ addr }} extended-link-bandwidth
{% endif %}
{% if n.extended_optional_parameters %}
 neighbor {{ addr }} extended-optional-parameters
{% endif %}
{# Three-valued: unset inherits the instance-level setting, the
   explicit forms render as written. #}
{% if n.enforce_first_as is true %}
 neighbor {{ addr }} enforce-first-as
{% elif n.enforce_first_as is false %}
 no neighbor {{ addr }} enforce-first-as
{% endif %}
{% if n.update_source %}
 neighbor {{ addr }} update-source {{ n.update_source }}
{% endif %}
{% if n.ip_transparent %}
 neighbor {{ addr }} ip-transparent
{% endif %}
{% if n.advertisement_interval is not none %}
 neighbor {{ addr }} advertisement-interval {{ n.advertisement_interval }}
{% endif %}
{% if n.timers.keepalive is not none %}
 neighbor {{ addr }} timers {{ n.timers.keepalive }} {{ n.timers.holdtime }}
{% endif %}
{% if n.timers.connect %}
 neighbor {{ addr }} timers connect {{ n.timers.connect }}
{% endif %}
{% if n.timers.delayopen %}
 neighbor {{ addr }} timers delayopen {{ n.timers.delayopen }}
{% endif %}
{# Capabilities. The three-valued ones ([no] capability dynamic /
   extended-nexthop / software-version [latest-encoding] / link-local)
   render nothing when unset and the explicit form otherwise; fqdn is
   on by default and only its negation is ever written
   (bgp_config_write_peer_global). #}
{% if n.capabilities.dynamic is true %}
 neighbor {{ addr }} capability dynamic
{% elif n.capabilities.dynamic is false %}
 no neighbor {{ addr }} capability dynamic
{% endif %}
{% if n.capabilities.extended_nexthop is true %}
 neighbor {{ addr }} capability extended-nexthop
{% elif n.capabilities.extended_nexthop is false %}
 no neighbor {{ addr }} capability extended-nexthop
{% endif %}
{% if n.capabilities.software_version is true %}
 neighbor {{ addr }} capability software-version
{% elif n.capabilities.software_version is false %}
 no neighbor {{ addr }} capability software-version
{% endif %}
{% if n.capabilities.software_version_latest_encoding is true %}
 neighbor {{ addr }} capability software-version latest-encoding
{% elif n.capabilities.software_version_latest_encoding is false %}
 no neighbor {{ addr }} capability software-version latest-encoding
{% endif %}
{% if n.rpki_strict %}
 neighbor {{ addr }} rpki strict
{% endif %}
{% if n.capabilities.link_local is true %}
 neighbor {{ addr }} capability link-local
{% elif n.capabilities.link_local is false %}
 no neighbor {{ addr }} capability link-local
{% endif %}
{% if n.capabilities.dont_capability_negotiate %}
 neighbor {{ addr }} dont-capability-negotiate
{% endif %}
{% if n.capabilities.fqdn is false %}
 no neighbor {{ addr }} capability fqdn
{% endif %}
{% if n.capabilities.override_capability %}
 neighbor {{ addr }} override-capability
{% endif %}
{% if n.capabilities.strict_capability_match %}
 neighbor {{ addr }} strict-capability-match
{% endif %}
{% if n.sender_as_path_loop_detection %}
 neighbor {{ addr }} sender-as-path-loop-detection
{% endif %}
{% if n.path_attribute_discard %}
 neighbor {{ addr }} path-attribute discard {{ n.path_attribute_discard | join(' ') }}
{% endif %}
{% if n.path_attribute_treat_as_withdraw %}
 neighbor {{ addr }} path-attribute treat-as-withdraw {{ n.path_attribute_treat_as_withdraw | join(' ') }}
{% endif %}
{# Per-neighbor graceful-restart role: one command per enum value
   (bgp_config_write_peer_global's peer_gr_new_status_flag block). #}
{% if n.graceful_restart_mode == "restarter" %}
 neighbor {{ addr }} graceful-restart
{% elif n.graceful_restart_mode == "helper" %}
 neighbor {{ addr }} graceful-restart-helper
{% elif n.graceful_restart_mode == "disable" %}
 neighbor {{ addr }} graceful-restart-disable
{% endif %}
{% if n.send_nexthop_characteristics %}
 neighbor {{ addr }} send-nexthop-characteristics
{% endif %}
{% endmacro %}
{% macro af_lines(addr, af) %}
{# activate is three-valued: unset follows the per-AF default
   activation, so only explicit true/false render. #}
{% if af.activate is true %}
  neighbor {{ addr }} activate
{% elif af.activate is false %}
  no neighbor {{ addr }} activate
{% endif %}
{# ADD-PATH: the tx enum maps onto three distinct commands
   (bgp_config_write_peer_af's addpath switch). #}
{% if af.addpath.tx == "all-paths" %}
  neighbor {{ addr }} addpath-tx-all-paths
{% elif af.addpath.tx == "best-per-as" %}
  neighbor {{ addr }} addpath-tx-bestpath-per-AS
{% elif af.addpath.tx == "best-selected" %}
  neighbor {{ addr }} addpath-tx-best-selected {{ af.addpath.tx_best_selected }}
{% endif %}
{% if af.addpath.disable_rx %}
  neighbor {{ addr }} disable-addpath-rx
{% endif %}
{% if af.addpath.rx_paths_limit is not none %}
  neighbor {{ addr }} addpath-rx-paths-limit {{ af.addpath.rx_paths_limit }}
{% endif %}
{% if af.orf_prefix_list %}
  neighbor {{ addr }} capability orf prefix-list {{ af.orf_prefix_list }}
{% endif %}
{% if af.route_reflector_client %}
  neighbor {{ addr }} route-reflector-client
{% endif %}
{% if af.next_hop_self.force %}
  neighbor {{ addr }} next-hop-self force
{% endif %}
{% if af.next_hop_self.enabled %}
  neighbor {{ addr }} next-hop-self
{% endif %}
{% if af.remove_private_as %}
{% set rpa_suffix = {"basic": "", "all": " all", "replace-as": " replace-AS", "all-replace-as": " all replace-AS"}[af.remove_private_as] %}
  neighbor {{ addr }} remove-private-AS{{ rpa_suffix }}
{% endif %}
{% if af.as_override %}
  neighbor {{ addr }} as-override
{% endif %}
{# FRR sends every community flavor by default and only writes the
   negations; extended-rpki is the exception (off by default). #}
{% if af.send_community.standard is false and af.send_community.extended is false and af.send_community.large is false %}
  no neighbor {{ addr }} send-community all
{% else %}
{% if af.send_community.standard is false %}
  no neighbor {{ addr }} send-community
{% endif %}
{% if af.send_community.extended is false %}
  no neighbor {{ addr }} send-community extended
{% endif %}
{% if af.send_community.large is false %}
  no neighbor {{ addr }} send-community large
{% endif %}
{% if af.send_community.extended_rpki %}
  neighbor {{ addr }} send-community extended rpki
{% endif %}
{% endif %}
{% if af.default_originate.enabled %}
{% set do_rmap = " route-map " ~ af.default_originate.route_map if af.default_originate.route_map else "" %}
  neighbor {{ addr }} default-originate{{ do_rmap }}
{% endif %}
{% if af.soft_reconfiguration_inbound %}
  neighbor {{ addr }} soft-reconfiguration inbound
{% endif %}
{% if af.maximum_prefix.count %}
{% set mp = af.maximum_prefix %}
{% set mp_threshold = " " ~ mp.threshold if mp.threshold else "" %}
{% set mp_warning = " warning-only" if mp.warning_only else "" %}
{% set mp_restart = " restart " ~ mp.restart_interval if mp.restart_interval else "" %}
{% set mp_force = " force" if mp.force else "" %}
  neighbor {{ addr }} maximum-prefix {{ mp.count }}{{ mp_threshold }}{{ mp_warning }}{{ mp_restart }}{{ mp_force }}
{% endif %}
{% if af.maximum_prefix_out %}
  neighbor {{ addr }} maximum-prefix-out {{ af.maximum_prefix_out }}
{% endif %}
{% if af.route_server_client %}
  neighbor {{ addr }} route-server-client
{% endif %}
{% if af.nexthop_local_unchanged %}
  neighbor {{ addr }} nexthop-local unchanged
{% endif %}
{% if af.allowas_in.enabled %}
{% set ai = af.allowas_in %}
{% set ai_rmap = " route-map " ~ ai.route_map if ai.route_map else "" %}
{% set ai_arg = " origin" if ai.origin else (" " ~ ai.count if ai.count is not none else "") %}
  neighbor {{ addr }} allowas-in{{ ai_rmap }}{{ ai_arg }}
{% endif %}
{% if af.accept_own %}
  neighbor {{ addr }} accept-own
{% endif %}
{% set soo_text = route_origin_text(af.soo) %}
{% if soo_text %}
  neighbor {{ addr }} soo {{ soo_text }}
{% endif %}
{% if af.weight is not none %}
  neighbor {{ addr }} weight {{ af.weight }}
{% endif %}
{# Per-neighbor filters, in bgp_config_write_filter()'s order:
   distribute-list, prefix-list, route-map, unsuppress-map,
   advertise-map, filter-list (bgpd/bgp_vty.c). #}
{% set f = af.filters %}
{% if f.distribute_list_in %}
  neighbor {{ addr }} distribute-list {{ f.distribute_list_in }} in
{% endif %}
{% if f.distribute_list_out %}
  neighbor {{ addr }} distribute-list {{ f.distribute_list_out }} out
{% endif %}
{% if f.prefix_list_in %}
  neighbor {{ addr }} prefix-list {{ f.prefix_list_in }} in
{% endif %}
{% if f.prefix_list_out %}
  neighbor {{ addr }} prefix-list {{ f.prefix_list_out }} out
{% endif %}
{% if f.route_map_in %}
  neighbor {{ addr }} route-map {{ f.route_map_in }} in
{% endif %}
{% if f.route_map_out %}
  neighbor {{ addr }} route-map {{ f.route_map_out }} out
{% endif %}
{% if f.unsuppress_map %}
  neighbor {{ addr }} unsuppress-map {{ f.unsuppress_map }}
{% endif %}
{% if f.conditional_advertisement.advertise_map %}
  neighbor {{ addr }} advertise-map {{ f.conditional_advertisement.advertise_map }} {{ f.conditional_advertisement.condition }}-map {{ f.conditional_advertisement.condition_map }}
{% endif %}
{% if f.filter_list_in %}
  neighbor {{ addr }} filter-list {{ f.filter_list_in }} in
{% endif %}
{% if f.filter_list_out %}
  neighbor {{ addr }} filter-list {{ f.filter_list_out }} out
{% endif %}
{% if af.attribute_unchanged.as_path or af.attribute_unchanged.next_hop or af.attribute_unchanged.med %}
{% set au_as_path = " as-path" if af.attribute_unchanged.as_path else "" %}
{% set au_next_hop = " next-hop" if af.attribute_unchanged.next_hop else "" %}
{% set au_med = " med" if af.attribute_unchanged.med else "" %}
  neighbor {{ addr }} attribute-unchanged{{ au_as_path }}{{ au_next_hop }}{{ au_med }}
{% endif %}
{# Route-flap dampening: bare, half-life only, or all four numbers
   (the schema 'must' guarantees no other combination). #}
{% if af.dampening.enabled %}
{% set nd = af.dampening %}
{% if nd.reuse_threshold is not none %}
{% set damp_args = " " ~ nd.half_life ~ " " ~ nd.reuse_threshold ~ " " ~ nd.suppress_threshold ~ " " ~ nd.max_suppress_time %}
{% elif nd.half_life is not none %}
{% set damp_args = " " ~ nd.half_life %}
{% else %}
{% set damp_args = "" %}
{% endif %}
  neighbor {{ addr }} dampening{{ damp_args }}
{% endif %}
{% endmacro %}
