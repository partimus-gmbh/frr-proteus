{# Per-neighbor lines of the l2vpn evpn address-family block. Shared
between the frr and experimental formats: these are session/policy
lines, not part of the legacy-vs-experimental EVPN scheme split.
`instance` is in scope from the including template. Peer-groups render
before neighbors, matching bgp_config_write_family()'s two loops; the
line vocabulary is the shared per-AF macro (FRR installs the same
commands in every address-family). #}
{% import "bgp_neighbor_macros.j2" as nb %}
{% for group in instance.peer_group %}
{{ nb.af_lines(group.name, group.afi_safis.l2vpn_evpn) -}}
{% endfor %}
{% for neighbor in instance.neighbor %}
{{ nb.af_lines(neighbor.address, neighbor.afi_safis.l2vpn_evpn) -}}
{% endfor %}
