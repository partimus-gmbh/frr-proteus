{# L2VPN EVPN address-family block, stock-FRR ("frr") format. Included
from bgp.conf.j2 when evpn_configured(instance) says the block is
needed; `instance` (the /bgp/instance entry) and `evpn`
(instance.afi_safis.l2vpn_evpn) are in scope from the caller.

Renders the legacy EVPN command set, plus a COMPATIBILITY TRANSLATION
of the experimental-scheme typing into stock FRR syntax:
  - vxlan-underlay  ->  'advertise-all-vni' (its direct stock
    equivalent; emitted once even if both fields are set).
  - vlan-based-evi with origination-l2vni N  ->  'vni N' block, with
    its fully qualified route-targets ('vni' RT lines support neither
    wildcard nor auto, so those are dropped, as is underlay-vrf);
    an EVI without origination-l2vni has no vni id and is dropped.
  - auto-discover-vnis, underlay-vrf, origination-l3vni have no
    stock-FRR equivalent and are left out.
The experimental format (bgp_evpn_af_experimental.j2) is the inverse:
new scheme emitted, legacy syntax removed. #}
{% import "evpn_macros.j2" as evpn_macros %}
 !
 address-family l2vpn evpn
{% include "bgp_evpn_neighbors.j2" %}
{% if evpn.advertise_all_vni or evpn.vxlan_underlay %}
  advertise-all-vni
{% endif %}
{% if evpn.advertise_default_gw %}
  advertise-default-gw
{% endif %}
{% if evpn.advertise_svi_ip %}
  advertise-svi-ip
{% endif %}
{% if evpn.enable_resolve_overlay_index %}
  enable-resolve-overlay-index
{% endif %}
{% if evpn.flooding %}
  flooding {{ evpn.flooding }}
{% endif %}
{% for vni in evpn.vni %}
  vni {{ vni.vni_id }}
{% if vni.rd %}
   rd {{ vni.rd }}
{% endif %}
{% for rt in route_target_texts(vni.route_target_import) %}
   route-target import {{ rt }}
{% endfor %}
{% for rt in route_target_texts(vni.route_target_export) %}
   route-target export {{ rt }}
{% endfor %}
{% for rt in route_target_texts(vni.route_target_both) %}
   route-target both {{ rt }}
{% endfor %}
{% if vni.flooding %}
   flooding {{ vni.flooding }}
{% endif %}
  exit-vni
{% endfor %}
{% for evi in evpn.vlan_based_evi %}
{% if evi.origination_l2vni %}
  vni {{ evi.origination_l2vni }}
{% for rt in route_target_texts(evi.route_target_import, include_wildcard=False) %}
   route-target import {{ rt }}
{% endfor %}
{% for rt in route_target_texts(evi.route_target_export) %}
   route-target export {{ rt }}
{% endfor %}
{% for rt in route_target_texts(evi.route_target_both) %}
   route-target both {{ rt }}
{% endfor %}
  exit-vni
{% endif %}
{% endfor %}
{% if evpn.rd %}
  rd {{ evpn.rd }}
{% endif %}
{{ evpn_macros.vrf_route_targets(evpn, "  ") -}}
{% if evpn.advertise_ipv4_unicast.enabled %}
{% set gw = " gateway-ip" if evpn.advertise_ipv4_unicast.gateway_ip else "" %}
{% set rmap = " route-map " ~ evpn.advertise_ipv4_unicast.route_map if evpn.advertise_ipv4_unicast.route_map else "" %}
  advertise ipv4 unicast{{ gw }}{{ rmap }}
{% endif %}
{% if evpn.advertise_ipv6_unicast.enabled %}
{% set gw = " gateway-ip" if evpn.advertise_ipv6_unicast.gateway_ip else "" %}
{% set rmap = " route-map " ~ evpn.advertise_ipv6_unicast.route_map if evpn.advertise_ipv6_unicast.route_map else "" %}
  advertise ipv6 unicast{{ gw }}{{ rmap }}
{% endif %}
 exit-address-family
