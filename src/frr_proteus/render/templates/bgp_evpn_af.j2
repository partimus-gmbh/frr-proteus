{# L2VPN EVPN address-family body. Included from bgp.conf.j2 when
evpn_configured(instance) says the block is needed; `instance` (the
/bgp/instance entry) and `evpn` (instance.afi_safis.l2vpn_evpn, see
yang/custom/proteus-bgp-evpn.yang) are in scope from the caller.

FRR distinguishes the default-instance EVPN role (advertise-all-vni, the
per-VNI list, flooding, ...) from a per-VRF instance's EVPN role (rd,
route-target, advertise ipv4/ipv6 unicast for L3VPN route leaking) by
which VRF the enclosing `router bgp` belongs to, not by YANG structure --
so this template just renders whichever fields are actually set,
regardless of instance role. #}
 !
 address-family l2vpn evpn
{% for neighbor in instance.neighbor %}
{% set addr = neighbor.address %}
{% set n_af = neighbor.afi_safis.l2vpn_evpn %}
{% if n_af.activate %}
  neighbor {{ addr }} activate
{% endif %}
{% if n_af.route_reflector_client %}
  neighbor {{ addr }} route-reflector-client
{% endif %}
{% if n_af.filters.route_map_in %}
  neighbor {{ addr }} route-map {{ n_af.filters.route_map_in }} in
{% endif %}
{% if n_af.filters.route_map_out %}
  neighbor {{ addr }} route-map {{ n_af.filters.route_map_out }} out
{% endif %}
{% if n_af.allowas_in.enabled %}
{% set count = " " ~ n_af.allowas_in.count if n_af.allowas_in.count else "" %}
  neighbor {{ addr }} allowas-in{{ count }}
{% endif %}
{% endfor %}
{% if evpn.advertise_all_vni %}
  advertise-all-vni
{% endif %}
{% if evpn.advertise_default_gw %}
  advertise-default-gw
{% endif %}
{% if evpn.advertise_svi_ip %}
  advertise-svi-ip
{% endif %}
{% if evpn.enable_resolve_overlay_index %}
  enable-resolve-overlay-index
{% endif %}
{% if evpn.flooding %}
  flooding {{ evpn.flooding }}
{% endif %}
{% for vni in evpn.vni %}
  vni {{ vni.vni_id }}
{% if vni.rd %}
   rd {{ vni.rd }}
{% endif %}
{% for rt in route_target_texts(vni.route_target_import) %}
   route-target import {{ rt }}
{% endfor %}
{% for rt in route_target_texts(vni.route_target_export) %}
   route-target export {{ rt }}
{% endfor %}
{% for rt in route_target_texts(vni.route_target_both) %}
   route-target both {{ rt }}
{% endfor %}
{% if vni.flooding %}
   flooding {{ vni.flooding }}
{% endif %}
  exit-vni
{% endfor %}
{% if evpn.rd %}
  rd {{ evpn.rd }}
{% endif %}
{% for rt in route_target_texts(evpn.route_target_import) %}
  route-target import {{ rt }}
{% endfor %}
{% if evpn.route_target_import.auto %}
  route-target import auto
{% endif %}
{% for rt in route_target_texts(evpn.route_target_export) %}
  route-target export {{ rt }}
{% endfor %}
{% if evpn.route_target_export.auto %}
  route-target export auto
{% endif %}
{% for rt in route_target_texts(evpn.route_target_both) %}
  route-target both {{ rt }}
{% endfor %}
{% if evpn.advertise_ipv4_unicast.enabled %}
{% set gw = " gateway-ip" if evpn.advertise_ipv4_unicast.gateway_ip else "" %}
{% set rmap = " route-map " ~ evpn.advertise_ipv4_unicast.route_map if evpn.advertise_ipv4_unicast.route_map else "" %}
  advertise ipv4 unicast{{ gw }}{{ rmap }}
{% endif %}
{% if evpn.advertise_ipv6_unicast.enabled %}
{% set gw = " gateway-ip" if evpn.advertise_ipv6_unicast.gateway_ip else "" %}
{% set rmap = " route-map " ~ evpn.advertise_ipv6_unicast.route_map if evpn.advertise_ipv6_unicast.route_map else "" %}
  advertise ipv6 unicast{{ gw }}{{ rmap }}
{% endif %}
 exit-address-family
