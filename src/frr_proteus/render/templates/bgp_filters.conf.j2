{# bgpd's global filter lists and community aliases.
   Text: bgpd/bgp_filter.c config_write_as_list ('bgp as-path
   access-list NAME seq SEQ <permit|deny> REGEX'), bgpd/bgp_vty.c
   community_list_config_write ('bgp community-list
   <standard|expanded> NAME seq SEQ <permit|deny> VALUE', likewise
   large-community-list / extcommunity-list; named lists only -- the
   numbered form is not modeled), bgpd/bgp_community_alias.c
   bgp_community_alias_write ('bgp community alias COMMUNITY ALIAS').
   Standard-list values are structured (proteus-types sets) and
   rendered by the community_texts / large_community_texts /
   extcommunity_texts helpers; raw fallback entries pass through
   verbatim. #}
{% for asp in bgp_filters.as_path_access_list %}
{% for c in comment_lines(asp) %}
! {{ c }}
{% endfor %}
{% for e in asp.entry %}
{% for c in comment_lines(e) %}
! {{ c }}
{% endfor %}
bgp as-path access-list {{ asp.name }} seq {{ e.sequence }} {{ e.action }} {{ e.regex }}
{% endfor %}
{% endfor %}
{% for cl in bgp_filters.community_list %}
{% for c in comment_lines(cl) %}
! {{ c }}
{% endfor %}
{% for e in cl.entry %}
{% for c in comment_lines(e) %}
! {{ c }}
{% endfor %}
{% set value = e.regex if cl.type == 'expanded' else community_texts(e.communities) | join(' ') %}
bgp community-list {{ cl.type }} {{ cl.name }} seq {{ e.sequence }} {{ e.action }} {{ value }}
{% endfor %}
{% endfor %}
{% for cl in bgp_filters.large_community_list %}
{% for c in comment_lines(cl) %}
! {{ c }}
{% endfor %}
{% for e in cl.entry %}
{% for c in comment_lines(e) %}
! {{ c }}
{% endfor %}
{% set value = e.regex if cl.type == 'expanded' else large_community_texts(e.large_communities) | join(' ') %}
bgp large-community-list {{ cl.type }} {{ cl.name }} seq {{ e.sequence }} {{ e.action }} {{ value }}
{% endfor %}
{% endfor %}
{% for cl in bgp_filters.extcommunity_list %}
{% for c in comment_lines(cl) %}
! {{ c }}
{% endfor %}
{% for e in cl.entry %}
{% for c in comment_lines(e) %}
! {{ c }}
{% endfor %}
{% set value = e.regex if cl.type == 'expanded' else extcommunity_texts(e.extcommunities) | join(' ') %}
bgp extcommunity-list {{ cl.type }} {{ cl.name }} seq {{ e.sequence }} {{ e.action }} {{ value }}
{% endfor %}
{% endfor %}
{% for alias in bgp_filters.community_alias %}
{% for c in comment_lines(alias) %}
! {{ c }}
{% endfor %}
bgp community alias {{ community_value_text(alias.community) }} {{ alias.name }}
{% endfor %}
